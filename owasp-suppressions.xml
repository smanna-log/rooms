<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!-- 
        OWASP Dependency Check Suppression File
        This file suppresses false positives and vulnerabilities from transitive dependencies
    -->

    <!-- Suppress vulnerabilities from transitive dependencies in Appium/Selenium -->
    <suppress>
        <notes><![CDATA[
            These vulnerabilities are from transitive dependencies in Appium and Selenium.
            They are not directly used in our test automation code.
            File name: netty-transport-*.jar
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/io\.netty/netty\-transport@.*$</packageUrl>
        <cve>CVE-2025-24970</cve>
        <cve>CVE-2026-33871</cve>
        <cve>CVE-2026-33870</cve>
        <cve>CVE-2023-44487</cve>
        <cve>CVE-2025-55163</cve>
        <cve>CVE-2025-58056</cve>
        <cve>CVE-2025-58057</cve>
    </suppress>

    <!-- Suppress OpenTelemetry vulnerabilities (transitive dependency) -->
    <suppress>
        <notes><![CDATA[
            OpenTelemetry is a transitive dependency used for monitoring.
            Not directly exposed in our application.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/io\.opentelemetry/.*@.*$</packageUrl>
        <cve>CVE-2026-39883</cve>
        <cve>CVE-2026-39882</cve>
    </suppress>

    <!-- Suppress Selenium OS vulnerabilities (transitive) -->
    <suppress>
        <notes><![CDATA[
            Selenium OS module vulnerability - transitive dependency
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.seleniumhq\.selenium/selenium\-os@.*$</packageUrl>
        <cve>CVE-2023-5590</cve>
    </suppress>

    <!-- Suppress ExtentReports JavaScript library vulnerabilities -->
    <suppress>
        <notes><![CDATA[
            These are embedded JavaScript libraries in ExtentReports for UI reporting.
            They are not executed in production or test code.
            File: extentreports-*.jar:spark-script.js
        ]]></notes>
        <packageUrl regex="true">^pkg:javascript/(bootstrap|chart\.js|jquery)@.*$</packageUrl>
        <cve>CVE-2020-7746</cve>
        <cve>CVE-2016-10735</cve>
        <cve>CVE-2018-14040</cve>
        <cve>CVE-2018-14041</cve>
        <cve>CVE-2018-14042</cve>
        <cve>CVE-2019-11358</cve>
        <cve>CVE-2019-8331</cve>
        <cve>CVE-2020-11022</cve>
        <cve>CVE-2020-11023</cve>
    </suppress>
</suppressions>
