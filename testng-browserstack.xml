<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<!-- Parallel execution enabled for cross-device testing on BrowserStack -->
<suite name="BrowserStack Parallel Suite" parallel="tests" thread-count="2" verbose="2">
    
    <listeners>
        <listener class-name="com.mobile.framework.utilities.AnnotationTransformer" />
    </listeners>
    
    <!-- Test execution on Samsung Galaxy S23 -->
    <test name="Android_Galaxy_S23_Tests" enabled="true">
        <!-- Passing remote device capabilities to @BeforeMethod -->
        <parameter name="deviceName" value="Samsung Galaxy S23" />
        <parameter name="platformVersion" value="13.0" />
        <parameter name="platformName" value="Android" />
        <classes>
            <class name="com.mobile.framework.tests.LoginTest" />
            <class name="com.mobile.framework.tests.SignupTest" />
            <class name="com.mobile.framework.tests.RegistrationTest" />
        </classes>
    </test>
    
    <!-- Test execution on Google Pixel 7 -->
    <test name="Android_Pixel_7_Tests" enabled="true">
        <parameter name="deviceName" value="Google Pixel 7" />
        <parameter name="platformVersion" value="13.0" />
        <parameter name="platformName" value="Android" />
        <classes>
            <class name="com.mobile.framework.tests.LoginTest" />
            <class name="com.mobile.framework.tests.SignupTest" />
            <class name="com.mobile.framework.tests.RegistrationTest" />
        </classes>
    </test>
    
</suite>
